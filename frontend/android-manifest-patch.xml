<!--
  ANDROID SHARE INTENT PATCH
  ===========================
  After running `npx cap add android` and `npx cap sync`, open:
    android/app/src/main/AndroidManifest.xml

  Find the <activity> tag that contains:
    android:name="com.secondmemory.app.MainActivity"

  Add the following <intent-filter> INSIDE that <activity> tag:
-->

<intent-filter>
    <action android:name="android.intent.action.SEND" />
    <category android:name="android.intent.category.DEFAULT" />
    <data android:mimeType="text/plain" />
</intent-filter>

