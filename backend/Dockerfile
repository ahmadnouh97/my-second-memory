FROM python:3.12-slim

WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Put the venv OUTSIDE /app so the dev volume mount doesn't clobber it
ENV UV_PROJECT_ENVIRONMENT=/opt/venv
# Use copy mode to avoid hardlink errors across filesystems
ENV UV_LINK_MODE=copy

# Install system dependencies
# Note: ffmpeg not needed — yt-dlp is used for metadata only (no download)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies with uv
# Copy lockfile if it exists (generated by `uv lock` locally)
COPY pyproject.toml uv.lock* ./
RUN uv sync --no-dev

# Install debugpy into the venv directly (kept outside pyproject.toml to
# avoid lock-file drift that triggers a full uv re-resolution at runtime)
RUN uv pip install --python /opt/venv debugpy

COPY . .

EXPOSE 8000

CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
