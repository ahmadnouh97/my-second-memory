DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/secondmemory
GROQ_API_KEY=your-groq-api-key
GOOGLE_API_KEY=your-google-api-key
APP_ENV=development
CORS_ORIGINS=http://localhost:8100,http://localhost:4200
JWT_SECRET=change-me-in-production
REGISTRATION_ENABLED=true

# Comma-separated list of allowed emails/patterns. Empty = nobody can register.
# Patterns: exact email, *@domain.com (domain wildcard), * (allow all)
# Example: alice@example.com,*@mycompany.com
REGISTRATION_ALLOWED_EMAILS=
